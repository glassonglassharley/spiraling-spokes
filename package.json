{
  "name": "axle",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/stream-canvas",
    "shared",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "npm run dev --workspace=apps/web",
    "compute-route": "tsx scripts/computeRoute.ts",
    "compute-test-route": "tsx scripts/computeRoute.ts --origin \"Santa Monica Pier, Los Angeles, CA\" --destination \"Venice Beach, Los Angeles, CA\" --interval 100 --avoid-highways --name \"Test Route — SM to Venice\"",
    "start-trip": "tsx scripts/startTrip.ts",
    "test-live-frame": "tsx scripts/testLiveFrame.ts",
    "test-frame": "tsx scripts/testFrame.ts",
    "test-street-view": "tsx scripts/testStreetView.ts",
    "test-tts": "tsx scripts/testTTS.ts",
    "test-weather": "tsx scripts/testWeather.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "psql $DATABASE_URL -f shared/db/schema.sql",
    "build": "npm run build --workspace=apps/web"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/tmi.js": "^1.8.6",
    "@types/ws": "^8.18.1",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "node-cron": "^3.0.0",
    "pg": "^8.11.0",
    "stripe": "^22.2.0",
    "tmi.js": "^1.8.5",
    "ws": "^8.16.0"
  }
}
