{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@axle/shared/*": ["./shared/*"]
    }
  },
  "include": ["server/**/*", "services/**/*", "workers/**/*", "scripts/**/*", "shared/**/*"],
  "exclude": ["node_modules", "apps", "dist"]
}
