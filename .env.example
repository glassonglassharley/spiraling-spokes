# Safety gate — must be exactly 'true' to enable any real API call.
# Leave unset or false for full mock mode (no charges, no external calls).
LIVE_MODE=false

# ─── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://axle:axle@localhost:5432/axle
REDIS_URL=redis://localhost:6379
PORT=8080
WEB_ORIGIN=http://localhost:3000

# ─── Google APIs (one key covers Directions, Street View, Geocoding, Elevation, Places) ──
GOOGLE_MAPS_API_KEY=

# ─── Anthropic — Claude Vision commentary + Haiku memory extraction ───────────
ANTHROPIC_API_KEY=

# ─── ElevenLabs — AXLE's voice ────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── OpenWeatherMap — weather per frame ───────────────────────────────────────
OPENWEATHERMAP_API_KEY=

# ─── Cloudflare R2 — caches Street View frames + audio (optional in dev) ──────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=axle-media
R2_CDN_URL=https://cdn.axle.live

# ─── Stripe — tips + subscriptions ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Auto-created on first LIVE_MODE=true startup; copy printed IDs here
STRIPE_PRICE_CREW_MONTHLY=
STRIPE_PRICE_LEGEND_MONTHLY=

# ─── NextAuth — viewer accounts ───────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Twitch — chat ingestion ──────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CHANNEL=axlelive

# ─── Next.js public vars ──────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_TWITCH_CHANNEL=axlelive
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
